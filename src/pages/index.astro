---
import Layout from '../layouts/Layout.astro';
import FadedFurButton from '../components/FadedFurButton.jsx';
---

<Layout title="AETHEREAL | Luxury Mental Health in London" description="Your bespoke, transformative path to resilience starts here.">
  
  <!-- Floating Element: 3D-like ambient cloud -->
  <div class="fixed bottom-[-15%] right-[-15%] w-[80vh] h-[80vh] opacity-40 pointer-events-none z-0 animate-slow-spin"
       style="background-image: url('/textures/white-fur.png'); background-size: cover; background-position: center; filter: blur(10px) brightness(1.2) contrast(1.1); mask-image: radial-gradient(circle, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 70%); -webkit-mask-image: radial-gradient(circle, rgba(0,0,0,1) 40%, rgba(0,0,0,0) 70%)">
  </div>

  <div class="relative z-10 flex flex-col items-center justify-center min-h-[90vh] text-center px-4 max-w-5xl mx-auto space-y-10">
    
    <div class="inline-block px-5 py-2 rounded-full bg-white/50 backdrop-blur-md text-gray-500 text-sm font-semibold tracking-widest border border-white/60 shadow-sm uppercase transition-all hover:bg-white hover:text-gray-800">
      AETHEREAL
    </div>
    
    <h1 style="font-family: 'Playfair Display', serif;" class="text-5xl md:text-6xl lg:text-7xl font-normal text-gray-900 leading-tight md:leading-snug">
      ELEVATING <span class="italic font-light text-gray-600">mental excellence</span><br class="hidden md:block" /> in London.
    </h1>
    
    <p class="text-lg md:text-xl lg:text-2xl font-light text-gray-600 max-w-2xl">
      Your bespoke, transformative path to resilience starts here.
    </p>
    
    <div class="pt-8 w-full flex justify-center">
      <FadedFurButton label="BOOK a Private Consultation" texture="pink" client:load />
    </div>

  </div>
</Layout>
