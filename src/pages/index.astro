---
import Layout from '../layouts/Layout.astro';
import FadedFurButton from '../components/FadedFurButton.jsx';
import FaqAccordion from '../components/FaqAccordion.jsx';

const furCard = {
  maroon: "background-image:url('/textures/pink-fur.png'); background-size:cover; background-position:center; filter:brightness(0.42) saturate(2) hue-rotate(-5deg);",
  teal:   "background-image:url('/textures/blue-fur.png');  background-size:cover; background-position:center; filter:brightness(0.52) saturate(1.6);",
  burgundy: "background-image:url('/textures/burgundy-wool.png'); background-size:cover; background-position:center; filter:brightness(0.6) contrast(1.1);",
};
---

<Layout title="AETHEREAL | Luxury Mental Health in London" description="Your bespoke, transformative path to resilience starts here.">

  <!-- ══ NAVBAR ══════════════════════════════════════════════ -->
  <nav class="w-full flex items-center justify-between px-8 py-5 border-b border-gray-100/50 bg-[#f8f9fb]/40 backdrop-blur-md sticky top-0 z-50">
    <span class="text-xs tracking-[0.4em] uppercase text-gray-800 font-semibold" style="font-family:'Playfair Display',serif;">AETHEREAL</span>
    <div class="hidden md:flex gap-10 text-[10px] tracking-[0.2em] text-gray-500 uppercase font-medium">
      <a href="#" class="hover:text-gray-900 transition-colors">Philosophy</a>
      <a href="#" class="hover:text-gray-900 transition-colors">Services</a>
      <a href="#" class="hover:text-gray-900 transition-colors">Clientele</a>
      <a href="#" class="hover:text-gray-900 transition-colors">Newsrooms</a>
    </div>
    <div class="flex gap-4 text-gray-400 text-sm">
      <span class="cursor-pointer hover:text-gray-600 transition-colors">✆</span>
      <span class="cursor-pointer hover:text-gray-600 transition-colors">⊕</span>
      <span class="cursor-pointer hover:text-gray-600 transition-colors">✉</span>
    </div>
  </nav>

  <!-- ══ HERO ════════════════════════════════════════════════ -->
  <section class="flex flex-col items-center text-center px-6 pt-24 pb-16 gap-10 max-w-3xl mx-auto relative overflow-hidden">
    
    <div class="absolute -top-10 -right-20 w-64 h-64 bg-pink-100/20 blur-[100px] rounded-full pointer-events-none"></div>
    <div class="absolute -bottom-10 -left-20 w-64 h-64 bg-blue-100/20 blur-[100px] rounded-full pointer-events-none"></div>

    <h1 class="text-5xl sm:text-6xl font-normal leading-tight text-gray-900 relative z-10" style="font-family:'Playfair Display',serif;">
      ELEVATING <em class="font-light not-italic" style="font-style:italic; color: #555;">mental<br/>excellence</em> in<br/>London
    </h1>

    <!-- Sensory Sanctuary badge: Enhanced Cushion Feel -->
    <div class="relative w-48 h-48 rounded-full shadow-2xl flex-shrink-0 group cursor-pointer transition-transform duration-700 hover:scale-105 active:scale-95">
      <div class="absolute inset-0 rounded-full border-[10px] border-white/40 backdrop-blur-sm z-20"></div>
      <div class="absolute inset-0 rounded-full overflow-hidden z-10">
        <div class="absolute inset-0" style="background-image:url('/textures/white-fur.png'); background-size:cover; background-position:center; filter: saturate(0.8) brightness(1.05);"></div>
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-1 px-4">
          <span class="text-4xl transition-transform duration-500 group-hover:scale-125">🐑</span>
          <p class="text-white font-bold text-[11px] tracking-[0.25em] uppercase text-center leading-tight mt-1" style="font-family:'Playfair Display',serif; text-shadow:0 1px 6px rgba(0,0,0,0.7);">SENSORY<br/>SANCTUARY</p>
          <div class="h-px w-6 bg-white/40 my-1"></div>
          <p class="text-white/80 text-[10px] tracking-widest text-center leading-tight font-medium" style="text-shadow:0 1px 4px rgba(0,0,0,0.6);">SOUL COMFORT</p>
        </div>
      </div>
      <div class="absolute -inset-2 bg-white/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
    </div>

    <p class="text-base text-gray-500 max-w-md leading-relaxed relative z-10 font-light" style="letter-spacing: 0.02em;">
      Your bespoke, transformative path to resilience starts here. Experience clinical excellence wrapped in pure sensory luxury.
    </p>

    <div class="relative z-10">
      <FadedFurButton label="✦  BOOK A PRIVATE CONSULTATION" texture="burgundy" client:load />
    </div>
  </section>

  <!-- ══ FEATURE CARDS ════════════════════════════════════=== -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-6 px-8 pb-24 max-w-6xl mx-auto w-full relative z-10">

    <!-- Maroon (Confidentiality) -->
    <div class="relative rounded-[2rem] overflow-hidden p-8 min-h-[220px] flex flex-col justify-between shadow-lg group hover:translate-y-[-5px] transition-transform duration-500">
      <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.maroon}></div>
      <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-500"></div>
      <div class="relative z-10 flex flex-col gap-3">
        <span class="text-white/90 text-2xl drop-shadow-md">🔒</span>
        <h3 class="text-white text-lg font-semibold leading-snug" style="font-family:'Playfair Display',serif;">Bespoke Confidentiality</h3>
        <p class="text-white/85 text-xs leading-relaxed max-w-[90%]">Discreet, confidential care crafted with exceptional precision to give you unparalleled peace of mind.</p>
      </div>
    </div>

    <!-- Teal (Path) -->
    <div class="relative rounded-[2rem] overflow-hidden p-8 min-h-[220px] flex flex-col justify-between shadow-lg group hover:translate-y-[-5px] transition-transform duration-500">
      <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.teal}></div>
      <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-500"></div>
      <div class="relative z-10 flex flex-col gap-3">
        <span class="text-white/90 text-2xl drop-shadow-md">✦</span>
        <h3 class="text-white text-lg font-semibold leading-snug" style="font-family:'Playfair Display',serif;">Tailored Transformative Path</h3>
        <p class="text-white/85 text-xs leading-relaxed max-w-[90%]">A methodology that draws from leading therapeutic traditions with compassionate and sound emotional health.</p>
      </div>
    </div>

    <!-- Burgundy (Results) -->
    <div class="relative rounded-[2rem] overflow-hidden p-8 min-h-[220px] flex flex-col justify-between shadow-lg group hover:translate-y-[-5px] transition-transform duration-500">
      <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.burgundy}></div>
      <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-500"></div>
      <div class="relative z-10 flex flex-col gap-3">
        <span class="text-white/90 text-2xl drop-shadow-md">🏆</span>
        <h3 class="text-white text-lg font-semibold leading-snug" style="font-family:'Playfair Display',serif;">Transformative Results</h3>
        <p class="text-white/85 text-xs leading-relaxed max-w-[90%]">Refined therapeutic outcomes that you will surely experience and bring life-long cognitive and mental health.</p>
      </div>
    </div>

  </section>

  <!-- ══ BESPOKE SERVICES ══════════════════════════════════== -->
  <section class="px-8 pb-24 max-w-6xl mx-auto w-full relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-normal text-gray-900 mb-4" style="font-family:'Playfair Display',serif;">
        Bespoke Services
      </h2>
      <div class="h-0.5 w-16 bg-gray-200 mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

      <!-- Individual Therapy: Teal -->
      <div class="relative rounded-[2.5rem] overflow-hidden p-10 min-h-[240px] flex flex-col justify-end group cursor-pointer shadow-md">
        <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.teal}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative z-10">
          <p class="text-white/90 text-2xl mb-2 drop-shadow-md">🧠</p>
          <h3 class="text-white text-xl font-semibold tracking-wide" style="font-family:'Playfair Display',serif;">Individual Therapy</h3>
          <p class="text-white/70 text-xs mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">Deep one-on-one transformative sessions.</p>
        </div>
      </div>

      <!-- Executive Coaching: Maroon -->
      <div class="relative rounded-[2.5rem] overflow-hidden p-10 min-h-[240px] flex flex-col justify-end group cursor-pointer shadow-md">
        <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.burgundy}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative z-10">
          <p class="text-white/90 text-2xl mb-2 drop-shadow-md">✚</p>
          <h3 class="text-white text-xl font-semibold tracking-wide" style="font-family:'Playfair Display',serif;">Executive Coaching</h3>
          <p class="text-white/70 text-xs mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">High-performance mental strategy for leaders.</p>
        </div>
      </div>

      <!-- Anxiety: Maroon -->
      <div class="relative rounded-[2.5rem] overflow-hidden p-10 min-h-[240px] flex flex-col justify-end group cursor-pointer shadow-md">
        <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.maroon}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative z-10">
          <p class="text-white/90 text-2xl mb-2 drop-shadow-md">🌊</p>
          <h3 class="text-white text-xl font-semibold tracking-wide" style="font-family:'Playfair Display',serif;">Anxiety &amp; Stress Management</h3>
          <p class="text-white/70 text-xs mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">Unlocking peace in a fast-paced world.</p>
        </div>
      </div>

      <!-- Mindfulness: Teal -->
      <div class="relative rounded-[2.5rem] overflow-hidden p-10 min-h-[240px] flex flex-col justify-end group cursor-pointer shadow-md">
        <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-110" style={furCard.teal}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
        <div class="relative z-10">
          <p class="text-white/90 text-2xl mb-2 drop-shadow-md">☁</p>
          <h3 class="text-white text-xl font-semibold tracking-wide" style="font-family:'Playfair Display',serif;">Mindfulness Sessions</h3>
          <p class="text-white/70 text-xs mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">Breath-work and sensory anchoring.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ HOVER BANNER (Soft Cushion) ══════════════════════════ -->
  <section class="px-8 pb-24 max-w-6xl mx-auto w-full relative z-10">
    <div class="relative rounded-[3rem] overflow-hidden p-20 text-center group cursor-pointer shadow-2xl transition-all duration-700">
      <div class="absolute inset-0 transition-all duration-1000 group-hover:scale-105" style={furCard. burgundy}></div>
      <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors duration-700"></div>
      <div class="relative z-10">
        <h2 class="text-white text-4xl font-light italic mb-6 tracking-wide" style="font-family:'Playfair Display',serif;">Step into a new era of care</h2>
        <p class="text-white/80 text-base max-w-lg mx-auto leading-relaxed font-light">
          Step into our sanctuary for a transformative journey today. London's leading mental health practice, where every thread is woven for your peace.
        </p>
        <div class="mt-10 opacity-0 group-hover:opacity-100 transition-all duration-700 translate-y-4 group-hover:translate-y-0">
           <span class="px-8 py-3 bg-white/10 backdrop-blur-md rounded-full text-white text-[10px] tracking-[0.3em] uppercase border border-white/20">Explore Philosophy</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FAQ ══════════════════════════════════════════════=== -->
  <section class="flex flex-col md:flex-row items-start gap-16 px-8 pb-24 max-w-6xl mx-auto w-full relative z-10">
    <div class="md:w-1/3">
      <h2 class="text-3xl font-normal text-gray-900 mb-6" style="font-family:'Playfair Display',serif;">Frequently<br/>Asked</h2>
      <p class="text-sm text-gray-500 leading-relaxed font-light">Common inquiries regarding our bespoke mental wellness protocols in London.</p>
    </div>
    <div class="md:w-2/3 w-full">
      <FaqAccordion client:load />
    </div>
  </section>

  <!-- ══ MAP (Stitched Border) ═══════════════════════════════ -->
  <section class="px-8 pb-16 max-w-6xl mx-auto w-full relative z-10">
    <div class="stitching p-2 bg-white/40 shadow-sm">
      <div class="rounded-[1.5rem] overflow-hidden grayscale hover:grayscale-0 transition-all duration-1000" style="height:350px;">
        <img
          src="/textures/london-map.png"
          alt="London Map"
          class="w-full h-full object-cover transition-transform duration-[10s] hover:scale-110"
          style="filter:contrast(0.9) brightness(1.02);"
        />
      </div>
    </div>
    <p class="text-center text-[9px] tracking-[0.4em] text-gray-400 mt-6 uppercase">SiteVibe Studio &mdash; Hand-Coded Architecture</p>
  </section>

</Layout>
